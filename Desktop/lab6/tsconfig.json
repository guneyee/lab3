{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "types": ["jest", "node"]
  },
  "include": ["src", "tests"]
}
